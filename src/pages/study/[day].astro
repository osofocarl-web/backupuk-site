---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/LucideIcon.astro';
import DailyStudyTracker from '../../components/DailyStudyTracker.jsx';
import planData from '../../data/biblePlan.json';

export const prerender = true;

export async function getStaticPaths() {
  return planData.map(entry => ({
    params: { day: `day-${entry.day}` },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<Layout title={`${entry.title} | 1-Year Bible Plan`}>
  <article class="daily-reading animate-fade-in">
    <header class="reading-header glass">
      <div class="header-content">
        <a href="/study" class="back-link">
          <Icon name="arrow-left" size={20} /> Back to 1-Year Plan
        </a>
        <div class="day-band">Yearly Plan</div>
        <h1>{entry.title}</h1>
      </div>
      <Icon name="book-open" class="header-bg-icon" />
    </header>

    <div class="reading-content-area">
        <div class="scripture-box glass">
            <h2>Today's Assigned Reading:</h2>
            <p class="reading-chapters">{entry.reading}</p>
            <p class="reading-instruction">Open your Bible or preferred Bible app and read the chapters assigned for today. Read slowly, take notes, and allow the Holy Spirit to minister to you.</p>
        </div>

        {/* Note: This is an Astro page, not React, but we can embed React components */}
        <DailyStudyTracker client:load dayId={`day-${entry.day}`} dayTitle={entry.title} />
    </div>
  </article>

  <style>
    .daily-reading {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 0;
    }

    .reading-header {
      position: relative;
      padding: 3rem;
      border-radius: var(--radius-lg);
      margin-bottom: 2rem;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: linear-gradient(135deg, rgba(17, 153, 142, 0.15) 0%, rgba(15, 23, 42, 0.8) 100%);
      border: 1px solid rgba(17, 153, 142, 0.3);
    }

    .header-content {
      position: relative;
      z-index: 2;
    }

    .day-band {
      display: inline-block;
      background: rgba(17, 153, 142, 0.2);
      color: #38ef7d;
      padding: 0.3rem 1rem;
      border-radius: 100px;
      font-weight: 700;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .reading-header h1 {
      font-size: 2.5rem;
      margin: 0;
      color: white;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text-muted);
      text-decoration: none;
      margin-bottom: 1.5rem;
      font-weight: 600;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: #38ef7d;
    }

    .header-bg-icon {
      position: absolute;
      right: -20px;
      bottom: -40px;
      width: 250px;
      height: 250px;
      color: rgba(17, 153, 142, 0.05);
      z-index: 1;
      transform: rotate(-15deg);
    }

    .scripture-box {
        padding: 3rem;
        border-radius: 16px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .scripture-box h2 {
        color: var(--color-text-muted);
        font-size: 1.25rem;
        margin-top: 0;
    }

    .reading-chapters {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--color-gold);
        margin: 1rem 0;
        line-height: 1.2;
        text-shadow: 0 4px 20px rgba(242, 153, 74, 0.2);
    }

    .reading-instruction {
        color: var(--color-text-muted);
        line-height: 1.6;
        max-width: 80%;
        margin: 0 auto;
        font-size: 1.1rem;
    }

    @media (max-width: 768px) {
      .reading-header {
        padding: 2rem;
      }
      
      .reading-header h1 {
        font-size: 2rem;
      }

      .reading-chapters {
          font-size: 2.5rem;
      }
      .reading-instruction {
          max-width: 100%;
      }
    }
  </style>
</Layout>
