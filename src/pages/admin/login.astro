---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/LucideIcon.astro';

// If admin is already logged in, they can go straight to the dashboard
// We do not do full role check here yet (handled on the next page), 
// just token presence to avoid repetitive logins
const { cookies, redirect } = Astro;
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (accessToken && refreshToken) {
  return redirect("/admin");
}
---

<Layout title="Admin Secure Login">
  <div class="admin-auth-container animate-fade-in">
    <div class="admin-auth-card glass">
      <div class="auth-header">
        <Icon name="shield-check" class="auth-icon-admin" />
        <h1>Admin Portal</h1>
        <p>Restricted access for authorized church leadership.</p>
      </div>

      <form id="admin-auth-form" class="auth-form">
        <div class="input-group">
          <label for="email">Administrator Email</label>
          <div class="input-with-icon">
            <Icon name="shield" size={18} />
            <input type="email" id="email" required placeholder="admin@lifeline.com" />
          </div>
        </div>

        <div class="input-group">
          <label for="password">Security Passkey</label>
          <div class="input-with-icon">
            <Icon name="key" size={18} />
            <input type="password" id="password" required placeholder="••••••••" />
          </div>
        </div>

        <div class="auth-actions">
          <button type="submit" id="admin-login-btn" class="btn-admin w-full">
            Secure Login <Icon name="lock" size={16} />
          </button>
        </div>
      </form>
      <div id="auth-message" class="auth-message hidden"></div>
      
      <div class="back-link-container">
        <a href="/auth" class="back-link"><Icon name="arrow-left" size={14}/> Return to Member Portal</a>
      </div>
    </div>
  </div>

  <style>
    .admin-auth-container {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 80vh;
      padding: 1rem;
    }

    .admin-auth-card {
      width: 100%;
      max-width: 450px;
      padding: 3rem 2.5rem;
      border-radius: var(--radius-lg);
      border: 1px solid rgba(233, 69, 96, 0.4);
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(233, 69, 96, 0.05) 100%);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8), 0 0 40px rgba(233, 69, 96, 0.1);
      position: relative;
    }

    .auth-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .auth-icon-admin {
      color: #e94560;
      width: 56px;
      height: 56px;
      margin-bottom: 1rem;
      filter: drop-shadow(0 0 10px rgba(233, 69, 96, 0.5));
    }

    .auth-header h1 {
      margin-bottom: 0.5rem;
      font-size: 2rem;
      color: white;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .auth-header p {
      color: var(--color-text-muted);
      font-size: 0.95rem;
    }

    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .input-group label {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .input-with-icon {
      position: relative;
      display: flex;
      align-items: center;
    }

    .input-with-icon :global(svg) {
      position: absolute;
      left: 1rem;
      color: #e94560;
    }

    .input-with-icon input {
      width: 100%;
      padding: 1rem 1rem 1rem 3rem;
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(233, 69, 96, 0.3);
      border-radius: var(--radius-sm);
      color: white;
      font-family: inherit;
      font-size: 1rem;
      transition: all 0.3s;
      outline: none;
    }

    .input-with-icon input:focus {
      border-color: #e94560;
      box-shadow: 0 0 0 2px rgba(233, 69, 96, 0.2);
    }

    .btn-admin {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem;
      background: #e94560;
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      font-weight: 800;
      font-size: 1.1rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 15px rgba(233, 69, 96, 0.4);
      margin-top: 1rem;
    }

    .btn-admin:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(233, 69, 96, 0.6);
      background: #ff5271;
    }

    .btn-admin:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    .auth-message {
      margin-top: 1.5rem;
      padding: 1rem;
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      text-align: center;
      font-weight: bold;
    }

    .auth-message.hidden {
      display: none;
    }

    .auth-message.error {
      background: rgba(233, 69, 96, 0.1);
      color: #ff5271;
      border: 1px solid rgba(233, 69, 96, 0.4);
    }

    .back-link-container {
      margin-top: 2rem;
      text-align: center;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text-muted);
      font-size: 0.85rem;
      text-decoration: none;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: white;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const form = document.getElementById('admin-auth-form') as HTMLFormElement;
    const loginBtn = document.getElementById('admin-login-btn');
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const messageEl = document.getElementById('auth-message');

    const showMessage = (msg: string) => {
      if (!messageEl) return;
      messageEl.textContent = msg;
      messageEl.className = 'auth-message error';
    };

    const setCookies = (access: string, refresh: string) => {
      document.cookie = `sb-access-token=${access}; path=/; max-age=3600; SameSite=Lax; secure`;
      document.cookie = `sb-refresh-token=${refresh}; path=/; max-age=31536000; SameSite=Lax; secure`;
    }

    if (form && loginBtn && emailInput && passwordInput) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value;
        const password = passwordInput.value;
        
        loginBtn.innerHTML = 'Verifying...';
        loginBtn.setAttribute('disabled', 'true');

        // 1. Authenticate standard credentials
        const { data, error } = await supabase.auth.signInWithPassword({
          email,
          password,
        });

        if (error) {
          showMessage("Invalid Admin Credentials or Session Error.");
          loginBtn.innerHTML = 'Secure Login <svg...>'; 
          loginBtn.removeAttribute('disabled');
        } else if (data.session) {
          
          // 2. Client-Side Role Check (Server-Side also enforces this, but this is a nice immediate UX stop)
          const { data: profile } = await supabase
              .from('profiles')
              .select('role')
              .eq('id', data.user.id)
              .single();
              
          if (profile && profile.role === 'admin') {
              setCookies(data.session.access_token, data.session.refresh_token);
              window.location.href = '/admin'; // Proceed to dashboard
          } else {
              // Sign them right back out, they don't belong here
              await supabase.auth.signOut();
              showMessage("ACCESS DENIED: Your account does not have Administrative privileges.");
              loginBtn.innerHTML = 'Secure Login <svg...>'; 
              loginBtn.removeAttribute('disabled');
          }
        }
      });
    }
  </script>
</Layout>
