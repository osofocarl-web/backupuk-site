---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/LucideIcon.astro';
import { supabase } from '../../lib/supabase';

// ============================================
// STRICT SERVER-SIDE SECURITY
// ============================================
export const prerender = false;

// 1. Verify standard session token presence
const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/admin/login");
}

let sessionUser = null;

try {
  // 2. Hydrate token with Supabase and retrieve the user id securely
  const { data: { user }, error: authError } = await supabase.auth.getUser(accessToken.value);
  if (authError || !user) throw new Error("Invalid session");
  sessionUser = user;

  // 3. SECURE ROLE VERIFICATION
  // We query the database specifically for the authenticated user ID and check their role
  const { data: profile, error: profileError } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();

  if (profileError || !profile || profile.role !== 'admin') {
      // INTRUDER DETECTED! Boot them to the standard dashboard
      return Astro.redirect("/");
  }

} catch (e) {
  // Token manipulation or expired
  Astro.cookies.delete("sb-access-token", { path: "/" });
  Astro.cookies.delete("sb-refresh-token", { path: "/" });
  return Astro.redirect("/admin/login");
}

// ============================================
// IF WE REACH HERE, THE USER IS A VERIFIED ADMIN
// ============================================

// Optional: Fetch some high-level stats to display on the dashboard
const { count: userCount } = await supabase.from('profiles').select('*', { count: 'exact', head: true });
const { count: attendanceCount } = await supabase.from('church_attendance').select('*', { count: 'exact', head: true });
const { data: kidsData } = await supabase.from('kids_progress').select('stars_earned');
const totalStars = kidsData ? kidsData.reduce((acc, curr) => acc + (curr.stars_earned || 0), 0) : 0;

---

<Layout title="Admin Dashboard">
  <div class="admin-wrapper animate-fade-in">
    <header class="admin-topbar glass">
      <div class="topbar-left">
        <Icon name="shield-check" class="admin-shield" />
        <h2>Lifeline Command Center</h2>
      </div>
      <div class="topbar-right">
        <span class="admin-badge">AUTHORIZED ADMIN</span>
        <button id="admin-logout" class="btn-logout"><Icon name="log-out" size={16}/> Sign Out</button>
      </div>
    </header>

    <main class="admin-dashboard">
      <section class="welcome-section">
        <h1>Welcome, Administrator</h1>
        <p>You have full access to monitor and manage the Lifeline Jacket platform.</p>
      </section>

      <div class="admin-stats-grid">
        <div class="admin-stat-card glass">
          <div class="stat-icon-wrapper users"><Icon name="users" /></div>
          <div class="stat-data">
            <span class="stat-num">{userCount || 0}</span>
            <span class="stat-label">Total Registered Users</span>
          </div>
        </div>

        <div class="admin-stat-card glass">
          <div class="stat-icon-wrapper church"><Icon name="church" /></div>
          <div class="stat-data">
            <span class="stat-num">{attendanceCount || 0}</span>
            <span class="stat-label">Lifetime Check-Ins</span>
          </div>
        </div>

        <div class="admin-stat-card glass">
          <div class="stat-icon-wrapper kids"><Icon name="star" /></div>
          <div class="stat-data">
            <span class="stat-num">{totalStars}</span>
            <span class="stat-label">Kids Stars Distributed</span>
          </div>
        </div>
      </div>

      <section class="admin-actions">
        <div class="glass panel placeholder-panel">
          <Icon name="settings" size={48} class="muted-icon" />
          <h3>System Settings</h3>
          <p>Global app configurations will appear here in future updates.</p>
        </div>
        <div class="glass panel placeholder-panel">
          <Icon name="database" size={48} class="muted-icon" />
          <h3>Data Management</h3>
          <p>Direct user database interfaces will appear here in future updates.</p>
        </div>
      </section>
    </main>
  </div>

  <style>
    .admin-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 0;
    }

    .admin-topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      border-radius: var(--radius-md);
      background: rgba(15, 23, 42, 0.9);
      border-bottom: 2px solid #e94560;
      margin-bottom: 2rem;
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .admin-shield {
      color: #e94560;
      width: 28px;
      height: 28px;
    }

    .topbar-left h2 {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .admin-badge {
      background: rgba(233, 69, 96, 0.2);
      color: #ff5271;
      border: 1px solid #e94560;
      padding: 0.2rem 0.8rem;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .btn-logout {
      background: transparent;
      border: none;
      color: var(--color-text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: bold;
      transition: color 0.2s;
    }

    .btn-logout:hover {
      color: white;
    }

    .welcome-section {
      margin-bottom: 2.5rem;
    }

    .welcome-section h1 {
      font-size: 2.2rem;
      margin: 0 0 0.5rem 0;
    }

    .welcome-section p {
      color: var(--color-text-muted);
      font-size: 1.1rem;
    }

    .admin-stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .admin-stat-card {
      display: flex;
      align-items: center;
      padding: 2rem;
      gap: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .stat-icon-wrapper {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: white;
    }

    .stat-icon-wrapper.users { background: linear-gradient(135deg, #4e54c8, #8f94fb); }
    .stat-icon-wrapper.church { background: linear-gradient(135deg, #11998e, #38ef7d); }
    .stat-icon-wrapper.kids { background: linear-gradient(135deg, #f2994a, #f2c94c); }

    .stat-data {
      display: flex;
      flex-direction: column;
    }

    .stat-num {
      font-size: 2.5rem;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .admin-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .placeholder-panel {
      padding: 3rem;
      text-align: center;
      border: 1px dashed rgba(255, 255, 255, 0.2);
    }

    .muted-icon {
      color: rgba(255, 255, 255, 0.1);
      margin-bottom: 1rem;
    }

    .placeholder-panel h3 {
      font-size: 1.25rem;
      margin: 0 0 0.5rem 0;
      color: var(--color-text-muted);
    }

    .placeholder-panel p {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.3);
      margin: 0;
    }

    @media (max-width: 768px) {
      .admin-topbar {
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
      }
      .admin-actions {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';
    
    const logoutBtn = document.getElementById('admin-logout');
    if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
            await supabase.auth.signOut();
            window.location.href = '/admin/login';
        });
    }
  </script>
</Layout>
