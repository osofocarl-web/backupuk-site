---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Icon from '../../components/LucideIcon.astro';

export async function getStaticPaths() {
  const entries = await getCollection('bible-school');
  return entries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <article class="module-page animate-fade-in">
    <header class="module-header glass">
      <div class="module-num">Module {entry.data.module}</div>
      <h1>{entry.data.title}</h1>
      <p class="desc">{entry.data.description}</p>
    </header>

    <div class="module-body">
      <div class="lesson-card glass">
        <Content />
      </div>

      <aside class="module-sidebar">
        <div class="sidebar-info glass">
          <h3><Icon name="check-square" /> Requirements</h3>
          <ul>
            <li><Icon name="book-open" size={16} /> Read all materials</li>
            <li><Icon name="pencil" size={16} /> Complete assignment</li>
            <li><Icon name="help-circle" size={16} /> Pass module quiz</li>
          </ul>
        </div>
        
        <button class="btn-primary complete-module-btn">
          <Icon name="check-circle" /> Mark Module Complete
        </button>
      </aside>
    </div>
  </article>

  <style>
    .module-page {
      padding: 1rem 0;
    }

    .module-header {
      padding: 2.5rem 2rem;
      text-align: center;
      margin-bottom: 2rem;
    }

    .module-num {
      text-transform: uppercase;
      font-weight: 800;
      color: var(--color-accent);
      margin-bottom: 0.5rem;
      letter-spacing: 0.1em;
    }

    .desc {
      color: var(--color-text-muted);
      max-width: 600px;
      margin: 0.5rem auto 0;
    }

    .module-body {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .lesson-card {
      padding: 2rem;
      line-height: 1.8;
    }

    .lesson-card :global(h3) {
      color: var(--color-gold);
      margin-top: 2rem;
    }

    .sidebar-info {
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .sidebar-info h3 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem;
      margin-bottom: 1rem;
    }

    .sidebar-info ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .sidebar-info li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }

    .btn-primary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 1rem;
      background: var(--gradient-accent);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      font-weight: 700;
      width: 100%;
      cursor: pointer;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(233, 69, 96, 0.5);
    }

    @media (min-width: 768px) {
      .module-body {
        grid-template-columns: 2fr 1fr;
      }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    document.addEventListener('DOMContentLoaded', () => {
      const completeBtn = document.querySelector('.complete-module-btn');
      const modulePath = window.location.pathname.split('/').filter(Boolean).pop();

      if (completeBtn && modulePath) {
        completeBtn.addEventListener('click', async () => {
          const { data: { user } } = await supabase.auth.getUser();

          if (!user) {
            alert('Please log in to track your module completion.');
            window.location.href = '/auth';
            return;
          }

          const originalText = completeBtn.innerHTML;
          completeBtn.innerHTML = 'Saving...';
          completeBtn.setAttribute('disabled', 'true');

          // 1. Record completed module
          const { error: moduleError } = await supabase
            .from('completed_modules')
            .upsert({ user_id: user.id, module_id: modulePath }, { onConflict: 'user_id, module_id' });

          if (moduleError) {
             alert(`Error saving progress: ${moduleError.message}`);
             completeBtn.innerHTML = originalText;
             completeBtn.removeAttribute('disabled');
             return;
          }

          // 2. Increment stats
          const { data: profile } = await supabase
            .from('profiles')
            .select('modules_done')
            .eq('id', user.id)
            .single();

          if (profile) {
            await supabase
              .from('profiles')
              .update({
                modules_done: profile.modules_done + 1
              })
              .eq('id', user.id);
          }

          completeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Completed!';
          completeBtn.classList.add('completed');
          completeBtn.classList.remove('btn-primary');
          completeBtn.setAttribute('style', 'background: var(--color-gold); color: black;');
        });
      }
    });
  </script>
</Layout>
