---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Icon from '../../components/LucideIcon.astro';

const modules = await getCollection('bible-school');
const sortedModules = modules.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Bible School">
  <section class="school-intro animate-fade-in">
    <div class="header-with-icon">
      <Icon name="graduation-cap" class="school-icon" />
      <h1>Bible School <span class="gold-text">Foundations</span></h1>
    </div>
    <p>Equivalent to a certificate-level Bible school foundational course.</p>
  </section>

  <div class="modules-grid animate-fade-in" style="animation-delay: 0.1s;">
    {sortedModules.map(mod => (
      <a href={`/bible-school/${mod.slug}`} class="module-card glass">
        <div class="module-icon-wrap">
          <Icon name={mod.data.icon as any} />
        </div>
        <div class="module-content">
          <div class="module-meta">Module {mod.data.module}</div>
          <h3>{mod.data.title}</h3>
          <p>{mod.data.description}</p>
        </div>
        <div class="module-footer">
          <span class="status-tag">Available</span>
          <Icon name="arrow-right" size={18} />
        </div>
      </a>
    ))}
  </div>

  <section class="certificate-info glass animate-fade-in" style="animation-delay: 0.2s;">
    <h3><Icon name="award" class="gold-text" /> Certification Path</h3>
    <p>Complete all 12 modules with at least 80% reading completion and pass all assessments to receive your <strong>Foundational Bible School Certificate</strong>.</p>
    <div class="path-steps">
      <div class="step"><Icon name="check-circle" /> 12 Modules</div>
      <div class="step"><Icon name="check-circle" /> Quizzes</div>
      <div class="step"><Icon name="check-circle" /> Final Assessment</div>
    </div>
  </section>

  <style>
    .school-intro {
      text-align: center;
      padding: 2rem 0;
    }

    .header-with-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .school-icon {
      color: var(--color-accent);
      width: 48px;
      height: 48px;
    }

    .gold-text { color: var(--color-gold); }

    .modules-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-top: 1rem;
    }

    .module-card {
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      transition: transform 0.3s, border-color 0.3s;
    }

    .module-card:hover {
      transform: translateY(-5px);
      border-color: var(--color-gold-muted);
    }

    .module-icon-wrap {
      width: 40px;
      height: 40px;
      background: var(--color-primary-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-gold);
      margin-bottom: 1rem;
    }

    .module-meta {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--color-accent);
      margin-bottom: 0.25rem;
    }

    .module-content h3 {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .module-content p {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      line-height: 1.5;
    }

    .module-footer {
      margin-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--color-glass-border);
    }

    .status-tag {
      font-size: 0.7rem;
      font-weight: 700;
      background: rgba(17, 153, 142, 0.2);
      color: #11998e;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
    }

    .certificate-info {
      margin-top: 3rem;
      padding: 2rem;
      border: 1px dashed var(--color-gold-muted);
    }

    .certificate-info h3 {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .path-steps {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .step {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--color-text-muted);
    }

    .step :global(svg) {
      color: #11998e;
    }

    @media (min-width: 640px) {
      .modules-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</Layout>
