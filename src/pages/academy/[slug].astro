---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import Icon from '../../components/LucideIcon.astro';
import AcademyQuiz from '../../components/AcademyQuiz.jsx';

export async function getStaticPaths() {
  const entries = await getCollection('academy');
  return entries.map(entry => ({
    params: { slug: entry.slug }
  }));
}

const { slug } = Astro.params;
const entry = await getEntry('academy', slug);

if (!entry) {
    return Astro.redirect('/academy');
}

const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
  <article class="module-page animate-fade-in">
    <header class="module-header glass">
      <div class="module-num">Module {entry.data.module}</div>
      <h1>{entry.data.title}</h1>
      <p class="desc">{entry.data.description}</p>
    </header>

    <div class="module-body">
      <div class="lesson-card glass">
        <Content />
        
        <div id="quiz-anchor">
           <AcademyQuiz client:load moduleId={entry.data.module} />
        </div>
      </div>

      <aside class="module-sidebar">
        <div class="sidebar-info glass">
          <h3><Icon name="check-square" /> Requirements</h3>
          <ul>
            <li><Icon name="book-open" size={16} /> Read all materials</li>
            <li><Icon name="help-circle" size={16} /> Complete Quiz (80%+)</li>
          </ul>
        </div>
        
        <div id="status-display" class="status-box glass">
           <Icon name="clock" id="status-icon" />
           <span id="status-text">Module In Progress</span>
        </div>
      </aside>
    </div>
  </article>

  <style>
    .module-page {
      padding: 1rem 0;
    }

    .module-header {
      padding: 2.5rem 2rem;
      text-align: center;
      margin-bottom: 2rem;
    }

    .module-num {
      text-transform: uppercase;
      font-weight: 800;
      color: var(--color-accent);
      margin-bottom: 0.5rem;
      letter-spacing: 0.1em;
    }

    .desc {
      color: var(--color-text-muted);
      max-width: 600px;
      margin: 0.5rem auto 0;
    }

    .module-body {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .lesson-card {
      padding: 2rem;
      line-height: 1.8;
    }

    .lesson-card :global(h3) {
      color: var(--color-gold);
      margin-top: 2rem;
    }

    .sidebar-info {
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .sidebar-info h3 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem;
      margin-bottom: 1rem;
    }

    .sidebar-info ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .sidebar-info li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }

    .status-box {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 1rem;
      border: 1px solid var(--color-glass-border);
      border-radius: var(--radius-sm);
      font-weight: 700;
      width: 100%;
      text-align: center;
      color: var(--color-text-muted);
      transition: all 0.3s ease;
    }

    .status-box.completed {
      background: rgba(56, 239, 125, 0.1);
      border-color: #38ef7d;
      color: #38ef7d;
    }

    @media (min-width: 768px) {
      .module-body {
        grid-template-columns: 2fr 1fr;
      }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    // Make the quiz completion handler available to the React component
    window.handleQuizCompletion = async (passed, score) => {
        const statusBox = document.getElementById('status-display');
        const statusText = document.getElementById('status-text');
        const statusIcon = document.getElementById('status-icon');
        const modulePath = window.location.pathname.split('/').filter(Boolean).pop();

        if (!passed) {
            return; // They failed, no database updates
        }

        if (statusBox && statusText) {
            statusText.innerText = 'Saving Progress...';
        }

        const { data: { user } } = await supabase.auth.getUser();

        if (!user) {
            alert('Please log in to track your module completion.');
            window.location.href = '/auth';
            return;
        }

        // 1. Record completed module
        const { error: moduleError } = await supabase
            .from('completed_modules')
            .upsert({ user_id: user.id, module_id: modulePath }, { onConflict: 'user_id, module_id' });

        if (moduleError) {
            alert(`Error saving progress: ${moduleError.message}`);
            if (statusBox && statusText) statusText.innerText = 'Error Saving';
            return;
        }

        // 2. Increment stats
        const { data: profile } = await supabase
            .from('profiles')
            .select('modules_done')
            .eq('id', user.id)
            .single();

        if (profile) {
            await supabase
                .from('profiles')
                .update({ modules_done: profile.modules_done + 1 })
                .eq('id', user.id);
        }

        // Update UI to show complete
        if (statusBox && statusText && statusIcon) {
            statusBox.classList.add('completed');
            statusText.innerText = `Completed (${score}%)`;
            statusIcon.innerHTML = `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>`;
        }
    };
  </script>
</Layout>
