---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Icon from '../../components/LucideIcon.astro';
import { supabase } from '../../lib/supabase';

export const prerender = false; // Need SSR for user specific stars

const lessons = await getCollection('children-zone');
const sortedLessons = lessons.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Fetch User Stars Server Side (or rely on client if standard static)
let totalStars = 0;
let isLoggedIn = false;

const { data: { session } } = await supabase.auth.getSession();
if (session?.user) {
    isLoggedIn = true;
    const { data: starsData } = await supabase
        .from('kids_progress')
        .select('stars_earned')
        .eq('user_id', session.user.id);
        
    if (starsData) {
        totalStars = starsData.reduce((sum, record) => sum + (record.stars_earned || 0), 0);
    }
}
---

<Layout title="Kids Zone">
  <section class="kids-intro animate-fade-in">
    <div class="header-with-icon">
      <Icon name="gamepad-2" class="kids-icon" />
      <h1>Kids <span class="gold-text">Zone</span></h1>
    </div>
    <p>Fun and interactive Bible learning for children.</p>
    
    <div class="stars-dashboard glass">
        <Icon name="star" class="star-icon" />
        <div class="star-count">
            <span class="count-value">{isLoggedIn ? totalStars : '?'}</span>
            <span class="count-label">Stars Earned</span>
        </div>
        {!isLoggedIn && <p class="login-prompt"><a href="/auth">Log in</a> to track your stars!</p>}
    </div>
  </section>

  <div class="lessons-grid animate-fade-in" style="animation-delay: 0.1s;">
    {sortedLessons.map(lesson => (
      <div class="lesson-card glass">
        <div class="age-band">Ages {lesson.data.ageBand}</div>
        <h3>{lesson.data.title}</h3>
        
        <div class="memory-verse">
          <h4>Memory Verse</h4>
          <p>"{lesson.data.memoryVerse}"</p>
        </div>

        <div class="questions">
          <h4>Questions</h4>
          <ul>
            {lesson.data.questions.map(q => (
              <li>{q}</li>
            ))}
          </ul>
        </div>
        
        <div class="action-footer">
           <a href={`/children/${lesson.slug}`} class="btn-play"><Icon name="play" size={16} /> Start Interactive Lesson</a>
        </div>
      </div>
    ))}
  </div>

  <style>
    .kids-intro {
      text-align: center;
      padding: 2rem 0;
    }

    .header-with-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .kids-icon {
      color: #f2994a;
      width: 48px;
      height: 48px;
    }

    .gold-text { color: var(--color-gold); }

    .stars-dashboard {
        display: inline-flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.5rem 2.5rem;
        margin-top: 2rem;
        border: 2px solid rgba(242, 153, 74, 0.3);
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.6);
        position: relative;
    }

    .star-icon {
        color: #f2c94c;
        width: 48px;
        height: 48px;
        filter: drop-shadow(0 0 10px rgba(242, 153, 74, 0.8));
    }

    .star-count {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1;
    }

    .count-value {
        font-size: 2.5rem;
        font-weight: 900;
        color: white;
    }

    .count-label {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .login-prompt {
        position: absolute;
        bottom: -35px;
        left: 0;
        width: 100%;
        text-align: center;
        font-size: 0.85rem;
        color: var(--color-text-muted);
        margin: 0;
    }

    .login-prompt a {
        color: #f2994a;
        text-decoration: none;
        font-weight: bold;
    }

    .lessons-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .lesson-card {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
      overflow: hidden;
      border: 1px solid var(--color-glass-border);
    }

    .lesson-card::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 150px;
      height: 150px;
      background: #f2994a;
      filter: blur(100px);
      opacity: 0.15;
      z-index: -1;
    }

    .age-band {
      align-self: flex-start;
      background: rgba(242, 153, 74, 0.2);
      color: #f2994a;
      padding: 0.3rem 0.8rem;
      border-radius: 100px;
      font-weight: 700;
      font-size: 0.8rem;
    }

    .lesson-card h3 {
      font-size: 1.4rem;
      color: white;
      margin: 0;
    }

    .memory-verse {
      background: rgba(255, 255, 255, 0.05);
      padding: 1rem;
      border-radius: 8px;
      border-left: 3px solid #f2994a;
    }

    .memory-verse h4, .questions h4 {
      font-size: 0.85rem;
      text-transform: uppercase;
      color: var(--color-text-muted);
      margin: 0 0 0.5rem 0;
    }

    .memory-verse p {
      font-style: italic;
      color: var(--color-gold);
      margin: 0;
    }

    .questions ul {
      list-style-type: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin: 0;
    }

    .questions li {
      display: flex;
      gap: 0.5rem;
      align-items: flex-start;
      font-size: 0.95rem;
      color: var(--color-text-muted);
    }
    
    .questions li::before {
      content: '•';
      color: #f2994a;
      font-weight: bold;
    }

    .action-footer {
      margin-top: auto;
      display: flex;
      justify-content: flex-end;
      padding-top: 1rem;
    }

    .btn-play {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.5rem;
      background: #f2994a;
      color: white;
      text-decoration: none;
      border: none;
      border-radius: var(--radius-sm);
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.3s, background 0.3s;
    }

    .btn-play:hover {
      transform: scale(1.05);
      background: #e67e22;
    }

    @media (min-width: 640px) {
      .lessons-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</Layout>
