---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/LucideIcon.astro';
---

<Layout title="My Notes">
  <section class="notes-intro animate-fade-in">
    <div class="header-with-icon">
      <Icon name="sticky-note" class="notes-icon" />
      <h1>My <span class="gold-text">Notes</span></h1>
    </div>
    <p>Chronicle your personal insights and revelations.</p>
  </section>

  <div class="notes-container animate-fade-in" style="animation-delay: 0.1s;">
    <div class="note-editor glass">
      <input type="text" id="noteTitle" placeholder="Note Title..." class="note-input" />
      <textarea id="noteContent" placeholder="Write your insights here..." class="note-textarea"></textarea>
      <div class="editor-actions">
        <button id="saveNote" class="btn-primary">
          <Icon name="save" size={18} /> Save Note
        </button>
      </div>
    </div>

    <div class="saved-notes">
      <h2>Recent Notes</h2>
      <div id="notesList" class="notes-grid">
        <!-- Notes will be injected here via JS -->
      </div>
    </div>
  </div>

  <style>
    .notes-intro {
      text-align: center;
      padding: 2rem 0;
    }

    .header-with-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .notes-icon {
      color: #9b59b6;
      width: 48px;
      height: 48px;
    }

    .gold-text { color: var(--color-gold); }

    .notes-container {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-top: 1.5rem;
    }

    .note-editor {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .note-input, .note-textarea {
      width: 100%;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--color-glass-border);
      border-radius: var(--radius-sm);
      color: white;
      padding: 1rem;
      font-family: inherit;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.3s;
    }

    .note-input:focus, .note-textarea:focus {
      border-color: #9b59b6;
    }

    .note-textarea {
      min-height: 200px;
      resize: vertical;
    }

    .editor-actions {
      display: flex;
      justify-content: flex-end;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.5rem;
      background: #9b59b6;
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.3s, background 0.3s;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      background: #8e44ad;
    }

    .saved-notes h2 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--color-accent);
      border-bottom: 1px solid var(--color-glass-border);
      padding-bottom: 0.5rem;
    }

    .notes-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    @media (min-width: 640px) {
      .notes-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    /* Styles for dynamically injected notes */
    :global(.note-item) {
      background: var(--color-glass);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid var(--color-glass-border);
      padding: 1.25rem;
      border-radius: var(--radius-md);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    
    :global(.note-item h3) {
      color: white;
      font-size: 1.1rem;
      margin: 0;
    }

    :global(.note-item p) {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
      line-height: 1.5;
    }

    :global(.note-item .date) {
      font-size: 0.75rem;
      color: #9b59b6;
      align-self: flex-start;
      margin-top: 0.5rem;
      font-weight: 600;
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    document.addEventListener('DOMContentLoaded', () => {
      const saveBtn = document.getElementById('saveNote');
      const titleInput = document.getElementById('noteTitle') as HTMLInputElement;
      const contentInput = document.getElementById('noteContent') as HTMLTextAreaElement;
      const notesList = document.getElementById('notesList');

      // Load notes
      const loadNotes = async () => {
        if (!notesList) return;
        
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) {
           notesList.innerHTML = '<p style="color: grey; font-style: italic;">Please log in to see notes.</p>';
           return;
        }

        const { data: notes, error } = await supabase
          .from('notes')
          .select('*')
          .order('created_at', { ascending: false });

        if (error) {
           notesList.innerHTML = `<p style="color: red;">Error loading notes: ${error.message}</p>`;
           return;
        }

        if (!notes || notes.length === 0) {
          notesList.innerHTML = '<p style="color: grey; font-style: italic;">No notes saved yet.</p>';
          return;
        }

        notesList.innerHTML = notes.map((note: any) => `
          <div class="note-item">
            <h3>${note.title}</h3>
            <p>${note.content}</p>
            <span class="date">${new Date(note.created_at).toLocaleDateString()}</span>
          </div>
        `).join('');
      };

      // Save note
      if (saveBtn && titleInput && contentInput) {
        saveBtn.addEventListener('click', async () => {
          const title = titleInput.value.trim();
          const content = contentInput.value.trim();

          if (!title || !content) {
            alert('Please enter both a title and content.');
            return;
          }

          const { data: { user } } = await supabase.auth.getUser();
          
          if (!user) {
             alert('You must be logged in to save a note.');
             return;
          }
          
          const oldText = saveBtn.innerHTML;
          saveBtn.innerHTML = 'Saving...';
          saveBtn.setAttribute('disabled', 'true');

          const { error } = await supabase
            .from('notes')
            .insert([
              { title, content, user_id: user.id }
            ]);

          saveBtn.innerHTML = oldText;
          saveBtn.removeAttribute('disabled');

          if (error) {
             alert(`Error saving note: ${error.message}`);
             return;
          }

          titleInput.value = '';
          contentInput.value = '';
          
          // Re-render
          loadNotes();
        });
      }

      // Initial load
      loadNotes();
    });
  </script>
</Layout>
