---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/LucideIcon.astro';
import { supabase } from '../../lib/supabase';
import planData from '../../data/biblePlan.json';

export const prerender = false; // SSR needed to fetch user specific completed days

let completedDaysMap = {};
let currentStreak = 0;
let isLoggedIn = false;

const { data: { session } } = await supabase.auth.getSession();
if (session?.user) {
    isLoggedIn = true;
    
    // Fetch completed days
    const { data: completed } = await supabase
        .from('completed_days')
        .select('day_id')
        .eq('user_id', session.user.id);
        
    if (completed) {
        completed.forEach(c => {
            completedDaysMap[c.day_id] = true;
        });
    }

    // Fetch streak
    const { data: profile } = await supabase
        .from('profiles')
        .select('day_streak')
        .eq('id', session.user.id)
        .single();
    if(profile) currentStreak = profile.day_streak || 0;
}

const getDayOfYear = () => {
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 0);
    const diff = (now - start) + ((start.getTimezoneOffset() - now.getTimezoneOffset()) * 60 * 1000);
    const oneDay = 1000 * 60 * 60 * 24;
    return Math.floor(diff / oneDay);
};

const todayIndex = getDayOfYear();
const totalCompleted = Object.keys(completedDaysMap).length;
const progressPercent = Math.round((totalCompleted / 365) * 100) || 0;
---

<Layout title="1-Year Bible Plan">
  <div class="study-dashboard animate-fade-in">
    <header class="plan-header glass">
      <div class="header-icon-bg">
        <Icon name="book-open" size={150} />
      </div>
      <div class="header-content">
        <h1>1-Year Bible Plan</h1>
        <p>Your daily journey through the Word of God.</p>
        
        <div class="header-stats">
          <div class="stat-box">
            <span class="stat-value">{totalCompleted}/365</span>
            <span class="stat-label">Days Finished</span>
          </div>
          <div class="stat-box">
            <span class="stat-value">{progressPercent}%</span>
            <span class="stat-label">Total Progress</span>
          </div>
          <div class="stat-box">
            <span class="stat-value"><span class="flame-icon">🔥</span> {currentStreak}</span>
            <span class="stat-label">Day Streak</span>
          </div>
        </div>

        <div class="header-actions">
           <a href={`/study/day-${todayIndex}`} class="btn-primary jump-btn">
               <Icon name="arrow-right-circle" /> Jump to Today (Day {todayIndex})
           </a>
        </div>
      </div>
    </header>

    <div class="plan-grid">
      {planData.map((day) => {
        const isCompleted = !!completedDaysMap[`day-${day.day}`];
        const isToday = day.day === todayIndex;
        
        return (
          <a 
            href={`/study/day-${day.day}`} 
            class={`day-card glass ${isCompleted ? 'completed' : ''} ${isToday ? 'today-pulse' : ''}`}
          >
            <div class="day-status">
              {isCompleted ? <Icon name="check-circle" class="status-icon parsed" /> : <div class="empty-circle"></div>}
            </div>
            <div class="day-details">
              <h3>{day.title} {isToday && <span class="today-badge">TODAY</span>}</h3>
              <p>{day.reading}</p>
            </div>
            <Icon name="chevron-right" class="arrow-icon" />
          </a>
        );
      })}
    </div>
  </div>

  <style>
    .study-dashboard {
      max-width: 1000px;
      margin: 0 auto;
      padding: 1rem 0;
    }

    .plan-header {
      position: relative;
      padding: 3rem 2rem;
      border-radius: var(--radius-lg);
      margin-bottom: 2rem;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(78, 84, 200, 0.15) 0%, rgba(15, 23, 42, 0.8) 100%);
      border: 1px solid rgba(78, 84, 200, 0.3);
    }

    .header-icon-bg {
      position: absolute;
      right: -20px;
      top: -20px;
      color: rgba(78, 84, 200, 0.05);
      transform: rotate(15deg);
      z-index: 0;
    }

    .header-content {
      position: relative;
      z-index: 1;
    }

    .plan-header h1 {
      font-size: 2.5rem;
      color: white;
      margin: 0 0 0.5rem 0;
    }
    
    .plan-header p {
      color: var(--color-text-muted);
      font-size: 1.1rem;
      margin-bottom: 2rem;
    }

    .header-stats {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .stat-box {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 1rem 1.5rem;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: white;
    }
    
    .flame-icon {
        color: #ff7e5f;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .btn-primary.jump-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--gradient-accent);
      padding: 1rem 2rem;
      border-radius: var(--radius-sm);
      color: white;
      text-decoration: none;
      font-weight: bold;
      box-shadow: 0 4px 15px rgba(233, 69, 96, 0.3);
      transition: all 0.2s;
    }

    .btn-primary.jump-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(233, 69, 96, 0.5);
    }

    /* Grid */
    .plan-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    @media (min-width: 768px) {
      .plan-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .day-card {
      display: flex;
      align-items: center;
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
      border: 1px solid var(--color-glass-border);
      transition: all 0.2s;
    }

    .day-card:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
      transform: translateY(-2px);
    }
    
    .today-pulse {
        border-color: #f2994a;
        box-shadow: 0 0 15px rgba(242, 153, 74, 0.2);
    }

    .day-status {
      margin-right: 1.25rem;
    }

    .empty-circle {
      width: 24px;
      height: 24px;
      border: 2px solid rgba(255, 255, 255, 0.2);
      border-radius: 50%;
    }

    .status-icon.parsed {
      color: #38ef7d;
      width: 24px;
      height: 24px;
    }

    .day-details {
      flex: 1;
    }

    .day-details h3 {
      font-size: 1.1rem;
      color: white;
      margin: 0 0 0.25rem 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .today-badge {
        background: #f2994a;
        color: #111;
        font-size: 0.65rem;
        padding: 0.15rem 0.5rem;
        border-radius: 100px;
        font-weight: bold;
    }

    .day-details p {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      margin: 0;
    }

    .arrow-icon {
      color: rgba(255, 255, 255, 0.2);
      transition: color 0.2s;
    }

    .day-card:hover .arrow-icon {
      color: white;
    }

    .day-card.completed .day-details h3 {
      color: var(--color-text-muted);
    }
  </style>
</Layout>
