{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/academy/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/academy/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/?$",
			"dest": "_render"
		},
		{
			"src": "^/children/?$",
			"dest": "_render"
		},
		{
			"src": "^/notes/?$",
			"dest": "_render"
		},
		{
			"src": "^/profile/?$",
			"dest": "_render"
		},
		{
			"src": "^/study/today/?$",
			"dest": "_render"
		},
		{
			"src": "^/study/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}